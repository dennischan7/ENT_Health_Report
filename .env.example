# =============================================
# Enterprise Health Report - Environment Variables
# =============================================
# Copy this file to .env and update the values

# Application
APP_NAME=Enterprise Health Report API
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql://health_user:health_password@postgres-kimi:5432/health_db_kimi

# Redis
REDIS_URL=redis://redis-kimi:6379/0

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-kimi
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma separated)
CORS_ORIGINS=["http://localhost:3005","http://127.0.0.1:3005"]

# LLM API Configuration (Phase 4)
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL_NAME=gpt-4

# External APIs (Phase 2+)
TUSHARE_TOKEN=your-tushare-token

# Frontend URL
FRONTEND_URL=http://localhost:3005
BACKEND_URL=http://localhost:8005